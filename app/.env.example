DATABASE_URL="postgresql://lms:lms@localhost:3942/lms?schema=public"
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3940"
COURSES_DIR="../courses"
PORT="3940"

# Seed + e2e login. prisma/seed.ts creates the local admin with these;
# e2e/creds.ts reads them to sign in. If SEED_PASSWORD is unset, the seed
# generates a random password and prints it once. Change it after first login.
SEED_ADMIN_EMAIL="admin@demo.local"
SEED_PASSWORD="choose-a-strong-local-password"
